// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model PropertyTypes {
  id   String @id @unique @default(uuid()) @map("id_entity_type")
  slug String @db.VarChar(75)
  name String @db.VarChar(75)

  properties Properties[]

  @@map("entity_types")
}

model Categories {
  id       String     @id @unique @default(uuid()) @map("id_category")
  slug     String     @db.VarChar(100)
  label    String     @db.VarChar(100)
  type     String     @db.VarChar(100)
  outcomes Outcomes[]
  incomes  Incomes[]

  @@map("categories")
}

model Directories {
  id        String @id @unique @default(uuid()) @map("id_directory")
  name      String @db.VarChar(120)
  firstName String @map("first_name") @db.VarChar(120)
  email     String @db.VarChar(250)
  phone     String @db.VarChar(20)
  address   String @db.VarChar(250)

  clients   Clients[]
  providers Providers[]
  users     Users[]

  @@map("directories")
}

model Users {
  id       String @id @unique @default(uuid()) @map("id_user")
  role     String @db.VarChar(100)
  status   String @db.VarChar(50)
  password String @db.VarChar(150)

  directoriesId String      @unique
  directory     Directories @relation(fields: [directoriesId], references: [id])

  properties Properties[]

  @@map("users")
}

model Properties {
  id            String    @unique @default(uuid()) @map("id_property")
  name          String    @db.VarChar(150)
  purchasePrice Int       @map("purchase_price") @db.Integer()
  purchaseDate  DateTime  @map("purchase_date")
  sellPrice     Int?      @map("sell_price") @db.Integer()
  sellDate      DateTime? @map("sell_date")
  isDeleted     Boolean   @default(false) @map("is_deleted")

  entityId String
  userId   String

  categorie PropertyTypes @relation(fields: [entityId], references: [id])
  user      Users         @relation(fields: [userId], references: [id])
  outcomes  Outcomes[]
  incomes   Incomes[]

  @@map("properties")
}

model Clients {
  id     String @unique @default(uuid()) @map("id_client")
  status String @db.VarChar(50)

  idDirectory   Directories @relation(fields: [directoriesId], references: [id])
  directoriesId String
  contracts     Contracts[]

  @@map("clients")
}

model Providers {
  id     String @unique @default(uuid()) @map("id_provider")
  status String @db.VarChar(50)

  directories   Directories @relation(fields: [directoriesId], references: [id])
  directoriesId String
  outcomes      Outcomes[]

  @@map("providers")
}

model Contracts {
  id        String   @unique @default(uuid()) @map("id_contract")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  lease     Int      @db.Integer()

  clientsId String

  incomes Incomes[]

  clientId Clients @relation(fields: [clientsId], references: [id])

  @@map("contracts")
}

model Incomes {
  id          String   @unique @default(uuid()) @map("id_income")
  name        String   @db.VarChar(75)
  amount      Int      @db.Integer()
  isRecurring Boolean  @map("is_recurring") @db.Boolean()
  isPaid      Boolean  @db.Boolean()
  issueDate   DateTime @db.Date()
  paidOn      DateTime @db.Date()
  frequency   String   @db.VarChar(50)

  contractsId  String
  propertiesId String
  categoriesId String

  contracts  Contracts  @relation(fields: [contractsId], references: [id])
  property   Properties @relation(fields: [propertiesId], references: [id])
  categories Categories @relation(fields: [categoriesId], references: [id])

  @@map("incomes")
}

model Outcomes {
  id          String   @unique @default(uuid()) @map("id_outcome")
  name        String   @db.VarChar(75)
  amount      Int      @db.Integer()
  isRecurring Boolean  @map("is_recurring") @db.Boolean()
  isPaid      Boolean  @db.Boolean()
  issueDate   DateTime @db.Date()
  paidOn      DateTime @db.Date()
  frequency   String   @db.VarChar(50)

  propertiesId String
  providersId  String
  categoriesId String

  property Properties @relation(fields: [propertiesId], references: [id])
  provider Providers  @relation(fields: [providersId], references: [id])
  category Categories @relation(fields: [categoriesId], references: [id])

  @@map("outcomes")
}
