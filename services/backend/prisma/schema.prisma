// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model PropertyTypes {
  id   String @id @unique @default(uuid()) @map("id_entity_type")
  slug String @unique @db.VarChar(75)
  name String @db.VarChar(75)

  properties Properties[]

  @@map("entity_types")
}

model Categories {
  id       String     @id @unique @default(uuid()) @map("id_category")
  slug     String     @unique @db.VarChar(100)
  label    String     @db.VarChar(100)
  type     String     @db.VarChar(100)
  outcomes Outcomes[]
  incomes  Incomes[]

  @@map("categories")
}

model Directories {
  id        String @id @unique @default(uuid()) @map("id_directory")
  name      String @db.VarChar(120)
  firstName String @map("first_name") @db.VarChar(120)
  email     String @db.VarChar(250)
  phone     String @db.VarChar(20)
  address   String @db.VarChar(250)
  type      String @db.VarChar(50)

  userId String

  user Users @relation(fields: [userId], references: [id])

  clients   Clients[]
  providers Providers[]

  @@map("directories")
}

model Users {
  id       String @id @unique @default(uuid()) @map("id_user")
  role     String @db.VarChar(100)
  status   String @db.VarChar(50)
  password String @db.VarChar(150)

  properties Properties[]
  contracts  Contracts[]
  directory  Directories[]

  @@map("users")
}

model Properties {
  id            String    @id @unique @default(uuid()) @map("id_property")
  name          String    @db.VarChar(150)
  purchasePrice Int       @map("purchase_price") @db.Integer()
  purchaseDate  DateTime  @map("purchase_date")
  sellPrice     Int?      @map("sell_price") @db.Integer()
  sellDate      DateTime? @map("sell_date")
  isDeleted     Boolean   @default(false) @map("is_deleted")

  typeId String
  userId String

  propertyType PropertyTypes @relation(fields: [typeId], references: [id])
  user         Users         @relation(fields: [userId], references: [id])
  outcomes     Outcomes[]
  incomes      Incomes[]

  @@map("properties")
}

model Clients {
  id     String @id @unique @default(uuid()) @map("id_client")
  status String @db.VarChar(50)

  directoriesId String
  idDirectory   Directories @relation(fields: [directoriesId], references: [id])
  contracts     Contracts[]

  @@map("clients")
}

model Providers {
  id     String @id @unique @default(uuid()) @map("id_provider")
  status String @db.VarChar(50)

  directories   Directories @relation(fields: [directoriesId], references: [id])
  directoriesId String
  outcomes      Outcomes[]

  @@map("providers")
}

model Contracts {
  id        String   @id @unique @default(uuid()) @map("id_contract")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  lease     Int      @db.Integer()

  clientId String
  userId   String

  incomes Incomes[]
  client  Clients   @relation(fields: [clientId], references: [id])
  user    Users     @relation(fields: [userId], references: [id])

  @@map("contracts")
}

model Incomes {
  id          String    @id @unique @default(uuid()) @map("id_income")
  name        String    @db.VarChar(75)
  amount      Int       @db.Integer()
  isRecurring Boolean   @map("is_recurring") @db.Boolean()
  isPaid      Boolean   @db.Boolean()
  issueDate   DateTime  @db.Date()
  paidOn      DateTime? @db.Date()
  frequency   String    @db.VarChar(50)

  propertyId String
  contractId String
  categoryId String

  property Properties @relation(fields: [propertyId], references: [id])
  contract Contracts  @relation(fields: [contractId], references: [id])
  category Categories @relation(fields: [categoryId], references: [id])

  @@map("incomes")
}

model Outcomes {
  id          String    @id @unique @default(uuid()) @map("id_outcome")
  name        String    @db.VarChar(150)
  amount      Int       @db.Integer()
  isRecurring Boolean   @map("is_recurring") @db.Boolean()
  isPaid      Boolean   @db.Boolean()
  issueDate   DateTime  @db.Date()
  paidOn      DateTime? @db.Date()
  frequency   String    @db.VarChar(50)

  propertyId String
  providerId String
  categoryId String

  property Properties @relation(fields: [propertyId], references: [id])
  provider Providers  @relation(fields: [providerId], references: [id])
  category Categories @relation(fields: [categoryId], references: [id])

  @@map("outcomes")
}
