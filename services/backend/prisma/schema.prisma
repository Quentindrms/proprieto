// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @unique @default(uuid()) @map("id_user") @db.Uuid
  name      String  @db.VarChar(120)
  firstName String  @map("first_name") @db.VarChar(120)
  address   String  @db.VarChar(250)
  email     String  @unique @db.VarChar(254)
  phone     String? @unique @db.VarChar(20)
  password  String  @db.VarChar(250)

  property Property[]

  @@map("user")
}

model PropertyType {
  id   String @id @unique @default(uuid()) @map("id_property") @db.Uuid
  slug String @unique @db.VarChar(150)
  name String @db.VarChar(150)

  property Property[]

  @@map("property_type")
}

model Client {
  id        String @id @unique @default(uuid()) @map("id_client") @db.Uuid
  name      String @db.VarChar(120)
  firstName String @map("first_name") @db.VarChar(120)
  email     String @db.VarChar(254)
  address   String @db.VarChar(250)
  phone     String @db.VarChar(20)

  income   Income[]
  contract Contract[]

  @@map("client")
}

model Providers {
  id        String @id @unique @default(uuid()) @map("id_provider") @db.Uuid
  name      String @db.VarChar(120)
  firstName String @map("first_name") @db.VarChar(120)
  email     String @db.VarChar(254)
  address   String @db.VarChar(250)
  phone     String @db.VarChar(20)

  outcome Outcome[]

  @@map("providers")
}

model OutcomeCategory {
  id   String @id @unique @default(uuid()) @map("id_outcome_category") @db.Uuid
  slug String @unique @db.VarChar(150)
  name String @db.VarChar(150)

  outcome Outcome[]

  @@map("outcome_category")
}

model IncomeCategory {
  id   String @id @unique @default(uuid()) @map("id_income_category") @db.Uuid
  slug String @unique @db.VarChar(150)
  name String @db.VarChar(150)

  income Income[]

  @@map("income_category")
}

model Property {
  id            String    @id @unique @default(uuid()) @map("id_property") @db.Uuid
  name          String    @db.VarChar(120)
  purchasePrice Int?      @map("purchase_price") @db.Integer()
  purchaseDate  DateTime? @map("purchase_date")
  sellPrice     Int?      @map("sell_price") @db.Integer()
  sellDate      DateTime? @map("sell_date")
  isDeleted     Boolean   @map("is_deleted")

  userId         String     @db.Uuid
  propertyTypeId String?    @db.Uuid
  income         Income[]
  outcome        Outcome[]
  contract       Contract[]

  user         User          @relation(fields: [userId], references: [id])
  propertyType PropertyType? @relation(fields: [propertyTypeId], references: [id])

  @@map("property")
}

model Outcome {
  id          String    @id @unique @default(uuid()) @map("id_outcome") @db.Uuid
  name        String    @db.VarChar(150)
  amount      Int       @db.Integer()
  isReccuring Boolean   @map("is_reccuring")
  isPaid      Boolean   @map("is_paid")
  issueDate   DateTime  @map("issue_date")
  paidOn      DateTime? @map("paid_on")
  frequency   String    @db.VarChar(50)

  propertyId        String @db.Uuid
  outcomeCategoryId String @db.Uuid
  providersId       String @db.Uuid

  property        Property        @relation(fields: [propertyId], references: [id])
  outcomeCategory OutcomeCategory @relation(fields: [outcomeCategoryId], references: [id])
  providers       Providers       @relation(fields: [providersId], references: [id])

  @@map("outcome")
}

model Income {
  id          String   @id @unique @default(uuid()) @map("id_income") @db.Uuid
  name        String   @db.VarChar(150)
  amount      Int      @db.Integer()
  isReccuring Boolean  @map("is_reccuring")
  isPaid      Boolean  @map("is_paid")
  issueDate   DateTime @map("issue_date")
  paidOn      DateTime @map("paid_on")
  frequency   String   @db.VarChar(50)

  propertyId       String  @db.Uuid
  incomeCategoryId String  @db.Uuid
  contractId       String? @db.Uuid
  clientId         String  @db.Uuid

  property       Property       @relation(fields: [propertyId], references: [id])
  incomeCategory IncomeCategory @relation(fields: [incomeCategoryId], references: [id])
  contract       Contract?      @relation(fields: [contractId], references: [id])
  client         Client         @relation(fields: [clientId], references: [id])

  @@map("income")
}

model Contract {
  id        String    @id @unique @default(uuid()) @map("id_contract") @db.Uuid
  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")
  lease     Int       @db.Integer()

  propertyId String   @db.Uuid
  clientId   String   @db.Uuid
  income     Income[]

  property Property @relation(fields: [propertyId], references: [id])
  client   Client   @relation(fields: [clientId], references: [id])

  @@map("contract")
}
